# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django – obligatorias ─────────────────────────────────────────────────────
# Genera una clave con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://dev:dev@localhost:5432/elpiecastillo

# ── Django – módulo de settings (dev | prod) ──────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Cloudinary – almacenamiento de medios (opcional) ─────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Producción – solo necesario en Render / Vercel ────────────────────────────
RENDER_EXTERNAL_URL=https://tu-app.onrender.com
FRONTEND_URL=https://tu-app.vercel.app
